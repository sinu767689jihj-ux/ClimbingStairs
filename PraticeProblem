class Solution{
    public int climbing(int n){
        if(n<=2)
        return n;
        int prev2=2;
        int prev1=1;
        for(int i=3;i<=n;i++){
            int current=prev1+prev2;
            prev1=prev2;
            prev2=current;
        }
        return prev2;
    }
    public static void main(String[] args){
        int n=10;
        Solution s=new Solution();
        System.out.println(s.climbing(n));
    }
}
