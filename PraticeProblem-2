class Solution{
    public int climbing(int n){
        if(n<=2)
        return n;
        int[] dp=new int[n+1];
         dp[1]=2;
         dp[2]=1;
        for(int i=3;i<=n;i++){
            dp[i]=dp[i-1]+dp[i-2];
            dp[2]=dp[1];
            dp[1]=dp[i];
        }
        return dp[n];
    }
    public static void main(String[] args){
        int n=10;
        Solution s=new Solution();
        System.out.println(s.climbing(n));
    }
}
